# Frontend build-time API base (required)
VITE_API_BASE_URL=/api

# Optional default login token for local/dev convenience.
# Leave empty in shared setups; login via UI token field instead.
VITE_API_TOKEN=

# API install seed (used by api/install.php)
THREAD_PILOT_ADMIN_NAME=Admin
THREAD_PILOT_ADMIN_ROLE=projectmanager

# FTP deploy script (npm run deploy:ftp)
FTP_HOST=
FTP_USER=
FTP_PASSWORD=
FTP_REMOTE_DIR=/html/apps/thread-pilot/
# FTP_PORT=21
# FTP_SECURE=false
